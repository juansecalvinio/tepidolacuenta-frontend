# Backend API URL
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_BASE_URL=localhost:8080

# Mode: development, production, none (none uses mocks)
VITE_MODE=development

# Sentry (observabilidad). Sin DSN, Sentry no se inicializa (dev local).
VITE_SENTRY_DSN=
# Opcional: distingue production / preview / dev en Sentry (si no, usa el MODE de Vite).
VITE_SENTRY_ENV=
# Opcional: versión/release (ej. el SHA del commit) para saber qué deploy metió cada error.
VITE_RELEASE=
